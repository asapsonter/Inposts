# Copy this file to .env and fill in your values.

# LinkedIn API (required for posting)
LINKEDIN_ACCESS_TOKEN=your_access_token_here
LINKEDIN_AUTHOR_URN=urn:li:person:your_person_id_here

# Ollama (defaults shown — change only if needed)
# OLLAMA_URL=http://localhost:11434/api/generate
# OLLAMA_MODEL=deepseek-r1
# OLLAMA_TIMEOUT=120

# SQLite database location (default: ./seen_articles.db)
# DB_PATH=./seen_articles.db

# Schedule (used by --loop mode)
# POST_HOUR=8
# POST_MINUTE=0

# Feed tuning
# MAX_ARTICLES=20
# HOTNESS_WINDOW_HOURS=24
